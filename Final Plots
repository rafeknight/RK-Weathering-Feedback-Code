#******* model base case ******* 
function cen_ode!(du, u, p, τ)
    w, a, λ, η, G, O = p
    C, T = u
    du[1] = (G(τ) - w(τ) * T) / a(τ)
    du[2] = (C + O(τ) - T / λ(τ)) / η
end

prob_template = ODEProblem(cen_ode!, [0.0, 0.0], (t[1], t[end]))


