#******* feedback plot ******* 
function model_feedback_post(chain, t;
    target = 660.0 / 1e2,
    tol = 10.0 / 1e2,
    eocene_age = 5.0,
    pCO2_grid = range(280.0, 2000.0; length = 300)
)
    n = length(t)

    #rescaled for Tmol
    G0_draws = vec(Array(chain[:G0])) ./ 1e2
    w0_draws = vec(Array(chain[:w0])) ./ 1e2
    σw_draws = vec(Array(chain[:σw]))

    λ0_draws = vec(Array(chain[:λ0]))
    σλ_draws = vec(Array(chain[:σλ]))

    δw_vecs = [vec(Array(chain[Symbol("δw[$i]")])) for i in 1:(n-1)]
    δw_post = hcat(δw_vecs...)'

    δλ_vecs = [vec(Array(chain[Symbol("δ[$i]")])) for i in 1:(n-1)]
    δλ_post = hcat(δλ_vecs...)'

    idx = findall(abs.(G0_draws .- target) .<= tol)

    G0_draws = G0_draws[idx]
    w0_draws = w0_draws[idx]
    σw_draws = σw_draws[idx]
    δw_post  = δw_post[:, idx]

    λ0_draws = λ0_draws[idx]
    σλ_draws = σλ_draws[idx]
    δλ_post  = δλ_post[:, idx]

    S = length(idx)

    Δlogw_draws = δw_post .* reshape(σw_draws, 1, :)
    Δlogλ_draws = δλ_post .* reshape(σλ_draws, 1, :)

    logw_paths = Array{Float64}(undef, n, S)
    logλ_paths = Array{Float64}(undef, n, S)

    #modern where w0, λ0 values were saved as modern values in the model output
    for j in 1:S
        logw0 = log(w0_draws[j])
        logλ0 = log(λ0_draws[j])

        logw_paths[:, j] = reverse([logw0; logw0 .+ cumsum(reverse(Δlogw_draws[:, j]))])
        logλ_paths[:, j] = reverse([logλ0; logλ0 .+ cumsum(reverse(Δlogλ_draws[:, j]))])
    end

    #w and λ at 55 myr ago
    #reminder that the model is formualted backwards
    #hence t = 5 is 55 myr ago
    w_5 = similar(w0_draws, S)
    λ_5 = similar(λ0_draws, S)

    for j in 1:S
        wlog_itp = LinearInterpolation(t, logw_paths[:, j])
        λlog_itp = LinearInterpolation(t, logλ_paths[:, j])

        logw5 = clamp(wlog_itp(eocene_age), log(1e-2), log(100.0))
        logλ5 = clamp(λlog_itp(eocene_age), log(1e-2), log(30.0))

        w_5[j] = exp(logw5)
        λ_5[j] = exp(logλ5)
    end

    #CO2 grid
    r_row = reshape(pCO2_grid ./ 280.0, 1, :)
    log2_row = log2.(r_row)

    G0_col = reshape(G0_draws, S, 1)
    mol_dbl0_col = reshape(w0_draws .* λ0_draws, S, 1)
    mol_dbl5_col = reshape(w_5 .* λ_5, S, 1)

    #rows = draws, cols = CO2 grid
    Fw0 = mol_dbl0_col .* log2_row .+ G0_col   #Modern
    Fw5 = mol_dbl5_col .* log2_row .+ G0_col   #Early Eocene

    return Fw0, Fw5, pCO2_grid
end

