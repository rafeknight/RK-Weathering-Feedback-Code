#******* ESS posterior trajectories *******
function ESS_post(chain, t; draws = 4500)
    n = length(t)

    λ0 = vec(Array(chain[:λ0]))
    σλ = vec(Array(chain[:σλ]))
    δ_mat = hcat([vec(Array(chain[Symbol("δ[$i]")])) for i in 1:n-1]...)

    Ndraw = length(λ0)
    nd = min(draws, Ndraw)

    λ_post = Matrix{Float64}(undef, n, nd)

    k = 0
    for j in 1:nd
        Δlogλ = σλ[j] .* vec(δ_mat[j, :])
        logλ_rw = reverse([log(λ0[j]); log(λ0[j]) .+ cumsum(reverse(Δlogλ))])
        λ_draw = exp.(clamp.(logλ_rw, log(1e-2), log(30.0)))

        
        k += 1
        λ_post[:, k] = λ_draw
    end

    λ_post = λ_post[:, 1:k]
    λ_post = reverse(λ_post; dims = 1)

    return λ_post
end

