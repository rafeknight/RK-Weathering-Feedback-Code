#******* C and T posteriors model base case ******* 
#variable names in the paper where switched to all be δs and σs 
#in the code ϵ etc.. all represent step size volatility terms
#see paper appendix for more details
function C_T_post!(chain1, t, prob_template, lo_vals, hi_vals, itp; draws = 4500)
    n = length(t)

    σfsr = vec(Array(chain1[:σfsr]))
    ζ_mat = hcat([vec(Array(chain1[Symbol("ζ[$i]")])) for i in 1:n-1]...)

    G0 = vec(Array(chain1[:G0]))

    λ0 = vec(Array(chain1[:λ0]))
    σλ = vec(Array(chain1[:σλ]))
    δ_mat = hcat([vec(Array(chain1[Symbol("δ[$i]")])) for i in 1:n-1]...)

    w0 = vec(Array(chain1[:w0]))
    σw = vec(Array(chain1[:σw]))
    δw_mat = hcat([vec(Array(chain1[Symbol("δw[$i]")])) for i in 1:n-1]...)

    ALK = vec(Array(chain1[:ALK]))
    σa = vec(Array(chain1[:σa]))
    ϵ_mat = hcat([vec(Array(chain1[Symbol("ϵ[$i]")])) for i in 1:n-1]...)

    η = vec(Array(chain1[:η]))
    CF = vec(Array(chain1[:CF]))
    TF = vec(Array(chain1[:TF]))

    Ndraw = length(σfsr)
    nd = min(draws, Ndraw)

    m_fsr = (lo_vals .+ hi_vals) ./ 2

    m = (9 / 420)
    SI_dbl = m / 3.7
    SI_0 = -SI_dbl * 60
    O(τ) = SI_0 + SI_dbl .* τ

    C_post = Matrix{Float64}(undef, n, nd)
    T_post = Matrix{Float64}(undef, n, nd)

    k = 0
    for j in 1:nd
        Δfsr = σfsr[j] .* vec(ζ_mat[j, :])
        fsr_rw = m_fsr .+ reverse([0.0; 0.0 .+ cumsum(reverse(Δfsr))])
        fsr = LinearInterpolation(t, fsr_rw)
        G(τ) = (G0[j] * fsr(τ)) - G0[j]

        Δlogλ = σλ[j] .* vec(δ_mat[j, :])
        logλ_rw = reverse([log(λ0[j]); log(λ0[j]) .+ cumsum(reverse(Δlogλ))])
        λlog = LinearInterpolation(t, logλ_rw)
        λ(τ) = exp(clamp(λlog(τ), log(1e-2), log(30.0)))

        Δlogw = σw[j] .* vec(δw_mat[j, :])
        logw_rw = reverse([log(w0[j]); log(w0[j]) .+ cumsum(reverse(Δlogw))])
        wlog = LinearInterpolation(t, logw_rw)
        w(τ) = exp(clamp(wlog(τ), log(1e-2), log(100.0)))

        Δa = σa[j] .* vec(ϵ_mat[j, :])
        a0 = max(itp(λ0[j], ALK[j]), 1e-2)
        a0_rw = reverse([0.0; 0.0 .+ cumsum(reverse(Δa))])
        a_rw = a0 .+ a0_rw
        a_itp = LinearInterpolation(t, a_rw)
        a(τ) = max(a_itp(τ), 1)

        u0 = [CF[j], TF[j]]
        prob = remake(prob_template, u0 = u0, p = (w, a, λ, η[j], G, O))
        sol = try
            solve(prob, Rodas5P(); saveat = t)
        catch
            nothing
        end

        if sol !== nothing && sol.retcode == SciMLBase.ReturnCode.Success && all(isfinite, Array(sol))
            k += 1
            C_post[:, k] = sol[1, :]
            T_post[:, k] = sol[2, :]
        end
    end

    C_post = C_post[:, 1:k]
    T_post = T_post[:, 1:k]

    C_post = reverse(C_post; dims = 1)
    T_post = reverse(T_post; dims = 1)

    return (C_post = C_post, T_post = T_post)
end


