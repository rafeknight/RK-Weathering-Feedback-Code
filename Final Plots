#******* G = G0 x fsr posteriors *******
function G_post(chain, t, lo_vals, hi_vals; draws = 4500)
    n = length(t)

    σfsr = vec(Array(chain[:σfsr]))
    ζ_draws = [vec(Array(chain[Symbol("ζ[$i]")])) for i in 1:(n-1)]
    samples = length(σfsr)

    nd = min(draws, samples)

    σfsr = σfsr[1:nd]

    Δfsr = hcat(ζ_draws...) .* reshape(vec(Array(chain[:σfsr])), :, 1)
    Δfsr = Δfsr[1:nd, :]

    m_fsr = (lo_vals .+ hi_vals) ./ 2

    fsr_post = Matrix{Float64}(undef, n, nd)
    for j in 1:nd
        Δ = Δfsr[j, :]
        fsr_post[:, j] = m_fsr .+ reverse([0.0; cumsum(reverse(Δ))])
    end

    G0_draws = vec(Array(chain[:G0])) ./ 100
    G0_draws = G0_draws[1:nd]

    G_post = reverse(fsr_post .* reshape(G0_draws, 1, :).- reshape(G0_draws, 1, :))

    G0_post = reverse(G0_draws)
    return G_post, G0_post
end

