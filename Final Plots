function C_T_post_inc_fsr!(chain5, t, prob_template, lo_vals_inc_fsr, hi_vals_inc_fsr, itp; draws = 4500)
    n = length(t)

    σfsr_inc_fsr = vec(Array(chain5[:σfsr]))
    ζ_mat_inc_fsr = hcat([vec(Array(chain5[Symbol("ζ[$i]")])) for i in 1:n-1]...)

    G0_inc_fsr = vec(Array(chain5[:G0]))

    λ0_inc_fsr = vec(Array(chain5[:λ0]))
    σλ_inc_fsr = vec(Array(chain5[:σλ]))
    δ_mat_inc_fsr = hcat([vec(Array(chain5[Symbol("δ[$i]")])) for i in 1:n-1]...)

    w0_inc_fsr = vec(Array(chain5[:w0]))
    σw_inc_fsr = vec(Array(chain5[:σw]))
    δw_mat_inc_fsr = hcat([vec(Array(chain5[Symbol("δw[$i]")])) for i in 1:n-1]...)

    ALK_inc_fsr = vec(Array(chain5[:ALK]))
    σa_inc_fsr = vec(Array(chain5[:σa]))
    ϵ_mat_inc_fsr = hcat([vec(Array(chain5[Symbol("ϵ[$i]")])) for i in 1:n-1]...)

    η_inc_fsr = vec(Array(chain5[:η]))
    CF_inc_fsr = vec(Array(chain5[:CF]))
    TF_inc_fsr = vec(Array(chain5[:TF]))

    Ndraw = length(σfsr_inc_fsr)
    nd = min(draws, Ndraw)

    m_fsr_inc_fsr = (lo_vals_inc_fsr .+ hi_vals_inc_fsr) ./ 2

    m = (9 / 420)
    SI_dbl = m / 3.7
    SI_0 = -SI_dbl * 60
    O_inc_fsr(τ) = SI_0 + SI_dbl .* τ

    C_post_inc_fsr = Matrix{Float64}(undef, n, nd)
    T_post_inc_fsr = Matrix{Float64}(undef, n, nd)

    k = 0
    for j in 1:nd
        Δfsr_inc_fsr = σfsr_inc_fsr[j] .* vec(ζ_mat_inc_fsr[j, :])
        fsr_rw_inc_fsr = m_fsr_inc_fsr .+ reverse([0.0; 0.0 .+ cumsum(reverse(Δfsr_inc_fsr))])
        fsr_inc_fsr = LinearInterpolation(t, fsr_rw_inc_fsr)
        G_inc_fsr(τ) = (G0_inc_fsr[j] * fsr_inc_fsr(τ)) - G0_inc_fsr[j]

        Δlogλ_inc_fsr = σλ_inc_fsr[j] .* vec(δ_mat_inc_fsr[j, :])
        logλ_rw_inc_fsr = reverse([log(λ0_inc_fsr[j]); log(λ0_inc_fsr[j]) .+ cumsum(reverse(Δlogλ_inc_fsr))])
        λlog_inc_fsr = LinearInterpolation(t, logλ_rw_inc_fsr)
        λ_inc_fsr(τ) = exp(clamp(λlog_inc_fsr(τ), log(1e-2), log(30.0)))

        Δlogw_inc_fsr = σw_inc_fsr[j] .* vec(δw_mat_inc_fsr[j, :])
        logw_rw_inc_fsr = reverse([log(w0_inc_fsr[j]); log(w0_inc_fsr[j]) .+ cumsum(reverse(Δlogw_inc_fsr))])
        wlog_inc_fsr = LinearInterpolation(t, logw_rw_inc_fsr)
        w_inc_fsr(τ) = exp(clamp(wlog_inc_fsr(τ), log(1e-2), log(100.0)))

        Δa_inc_fsr = σa_inc_fsr[j] .* vec(ϵ_mat_inc_fsr[j, :])
        a0_inc_fsr = max(itp(λ0_inc_fsr[j], ALK_inc_fsr[j]), 1e-2)
        a0_rw_inc_fsr = reverse([0.0; 0.0 .+ cumsum(reverse(Δa_inc_fsr))])
        a_rw_inc_fsr = a0_inc_fsr .+ a0_rw_inc_fsr
        a_itp_inc_fsr = LinearInterpolation(t, a_rw_inc_fsr)
        a_inc_fsr(τ) = max(a_itp_inc_fsr(τ), 1)

        u0_inc_fsr = [CF_inc_fsr[j], TF_inc_fsr[j]]
        prob_inc_fsr = remake(prob_template, u0 = u0_inc_fsr, p = (w_inc_fsr, a_inc_fsr, λ_inc_fsr, η_inc_fsr[j], G_inc_fsr, O_inc_fsr))
        sol_inc_fsr = try
            solve(prob_inc_fsr, Rodas5P(); saveat = t)
        catch
            nothing
        end

        if sol_inc_fsr !== nothing && sol_inc_fsr.retcode == SciMLBase.ReturnCode.Success && all(isfinite, Array(sol_inc_fsr))
            k += 1
            C_post_inc_fsr[:, k] = sol_inc_fsr[1, :]
            T_post_inc_fsr[:, k] = sol_inc_fsr[2, :]
        end
    end

    C_post_inc_fsr = C_post_inc_fsr[:, 1:k]
    T_post_inc_fsr = T_post_inc_fsr[:, 1:k]

    C_post_inc_fsr = reverse(C_post_inc_fsr; dims = 1)
    T_post_inc_fsr = reverse(T_post_inc_fsr; dims = 1)

    return (C_post_inc_fsr = C_post_inc_fsr, T_post_inc_fsr = T_post_inc_fsr)
end


