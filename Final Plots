function O_post(chain, t; draws = 4500)
    n = length(t)

    m = 9 / 420
    SI_dbl = m / 3.7
    SI_0 = -SI_dbl * 60
    O_det = SI_0 .+ SI_dbl .* t

    Ofsr = vec(Array(chain[:Ofsr]))
    Oζ_mat = hcat([vec(Array(chain[Symbol("Oζ[$i]")])) for i in 1:n-1]...)

    Ndraw = length(Ofsr)
    nd = min(draws, Ndraw)

    O_post_mat = Matrix{Float64}(undef, n, nd)

    k = 0
    for j in 1:nd
        ΔO = Ofsr[j] .* vec(Oζ_mat[j, :])
        O_rw = reverse([0.0; cumsum(reverse(ΔO))])

        k += 1
        O_post_mat[:, k] = O_rw
    end

    O_post_mat = O_post_mat[:, 1:k] .- O_det
    O_post_mat = reverse(O_post_mat; dims = 1)

    return O_post_mat
end

